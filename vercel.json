{
  "version": 2,
  "rewrites": [
    { "source": "/api/iol",        "destination": "/api/brokers/iol" },
    { "source": "/api/balanz",     "destination": "/api/brokers/balanz" },
    { "source": "/api/ppi",        "destination": "/api/brokers/ppi" },
    { "source": "/api/bullmarket", "destination": "/api/brokers/bullmarket" },
    { "source": "/api/cocos",      "destination": "/api/brokers/cocos" },
    { "source": "/api/rava",       "destination": "/api/brokers/rava" },
    { "source": "/api/lemon",      "destination": "/api/brokers/lemon" },
    { "source": "/api/bitso",      "destination": "/api/brokers/bitso" },
    { "source": "/api/aurum",      "destination": "/api/brokers/aurum" },
    { "source": "/api/puente",     "destination": "/api/brokers/puente" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" },
        { "key": "Access-Control-Max-Age",       "value": "86400" }
      ]
    }
  ]
}
